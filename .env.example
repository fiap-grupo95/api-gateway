# api-gateway — variáveis de ambiente
# Copie para .env e preencha os valores obrigatórios

PORT=8080

# Endereços dos serviços upstream (nomes dos containers na rede hacka-net)
UPLOAD_ORCHESTRATOR_URL=http://upload-orchestrator:8081
REPORT_SERVICE_URL=http://report-service:8083

MAX_UPLOAD_SIZE_MB=10
ALLOWED_MIME_TYPES=image/png,image/jpeg,image/webp,application/pdf

# JWT — mínimo 32 caracteres
JWT_SECRET=

# Credenciais de login
# Para gerar o hash: htpasswd -bnBC 10 "" suasenha | tr -d ':\n'
AUTH_USERNAME=
AUTH_PASSWORD_HASH=
